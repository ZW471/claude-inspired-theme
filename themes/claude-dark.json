  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#6F6F78",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["string", "string.quoted", "string.template"],
      "settings": {
        "foreground": "#8FA870"
      }
    },
    {
      "scope": ["constant.numeric", "constant.language.boolean"],
      "settings": {
        "foreground": "#45B0B0"
      }
    },
    {
      "scope": ["constant.language", "constant.character", "constant.other"],
      "settings": {
        "foreground": "#45B0B0"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#E87DA8"
      }
    },
    {
      "scope": ["keyword.operator", "keyword.operator.assignment"],
      "settings": {
        "foreground": "#E8E6DC"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call entity.name.function"
      ],
      "settings": {
        "foreground": "#85B5E0"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class",
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#A872D9"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter",
        "meta.function.parameters variable"
      ],
      "settings": {
        "foreground": "#D49A3C"
      }
    },
    {
      "scope": ["variable", "variable.other"],
      "settings": {
        "foreground": "#E8E6DC"
      }
    },
    {
      "scope": ["variable.other.property", "variable.other.object.property"],
      "settings": {
        "foreground": "#E8E6DC"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#E06B5E"
      }
    },
    {
      "scope": ["entity.other.attribute-name"],
      "settings": {
        "foreground": "#D49A3C"
      }
    },
    {
      "scope": ["support.constant", "variable.other.constant"],
      "settings": {
        "foreground": "#45B0B0"
      }
    },
    {
      "scope": ["meta.decorator", "entity.name.function.decorator"],
      "settings": {
        "foreground": "#D49A3C"
      }
    },
    {
      "scope": [
        "punctuation.section",
        "punctuation.separator",
        "punctuation.accessor",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#9A9893"
      }
    },
    {
      "scope": ["string.regexp"],
      "settings": {
        "foreground": "#E06B5E"
      }
    },
    {
      "scope": ["constant.character.escape", "string.template punctuation.definition"],
      "settings": {
        "foreground": "#45B0B0"
      }
    },
    {
      "scope": ["entity.name.namespace", "entity.name.module"],
      "settings": {
        "foreground": "#A872D9"
      }
    },
    {
      "scope": ["markup.heading"],
      "settings": {
        "foreground": "#D97757",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["markup.bold"],
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["markup.italic"],
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["markup.inline.raw", "markup.fenced_code"],
      "settings": {
        "foreground": "#45B0B0"
      }
    },
    {
      "scope": ["markup.underline.link"],
      "settings": {
        "foreground": "#85B5E0"
      }
    },
    {
      "scope": ["markup.inserted"],
      "settings": {
        "foreground": "#8FA870"
      }
    },
    {
      "scope": ["markup.deleted"],
      "settings": {
        "foreground": "#E06B5E"
      }
    },
    {
      "scope": ["markup.changed"],
      "settings": {
        "foreground": "#D97757"
      }
    },
    {
      "scope": [
        "source.json support.type.property-name"
      ],
      "settings": {
        "foreground": "#D97757"
      }
    },
    {
      "scope": ["support.type.property-name.css"],
      "settings": {
        "foreground": "#85B5E0"
      }
    },
    {
      "scope": [
        "support.constant.color",
        "constant.other.color",
        "support.constant.property-value.css"
      ],
      "settings": {
        "foreground": "#45B0B0"
      }
    },
    {
      "scope": ["entity.name.section", "entity.name.tag.yaml"],
      "settings": {
        "foreground": "#D97757"
      }
    },
    {
      "scope": ["variable.language"],
      "settings": {
        "foreground": "#E87DA8",
        "fontStyle": "italic"
      }
    }
  ],
  "semanticTokenColors": {
    "function": "#85B5E0",
    "function.declaration": "#85B5E0",
    "method": "#85B5E0",
    "method.declaration": "#85B5E0",
    "variable": "#E8E6DC",
    "variable.readonly": "#45B0B0",
    "parameter": "#D49A3C",
    "property": "#E8E6DC",
    "type": "#A872D9",
    "class": "#A872D9",
    "interface": "#A872D9",
    "enum": "#A872D9",
    "enumMember": "#45B0B0",
    "namespace": "#A872D9",
    "decorator": "#D49A3C",
    "macro": "#E87DA8"
  }
}
