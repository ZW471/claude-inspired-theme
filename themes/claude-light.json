  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#6F6F78",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["string", "string.quoted", "string.template"],
      "settings": {
        "foreground": "#26831A"
      }
    },
    {
      "scope": ["constant.numeric", "constant.language.boolean"],
      "settings": {
        "foreground": "#2D8F8F"
      }
    },
    {
      "scope": ["constant.language", "constant.character", "constant.other"],
      "settings": {
        "foreground": "#2D8F8F"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#D73A83"
      }
    },
    {
      "scope": ["keyword.operator", "keyword.operator.assignment"],
      "settings": {
        "foreground": "#1F1E1D"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call entity.name.function"
      ],
      "settings": {
        "foreground": "#1F6FE4"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class",
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#8A46CE"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter",
        "meta.function.parameters variable"
      ],
      "settings": {
        "foreground": "#B56613"
      }
    },
    {
      "scope": ["variable", "variable.other"],
      "settings": {
        "foreground": "#1F1E1D"
      }
    },
    {
      "scope": ["variable.other.property", "variable.other.object.property"],
      "settings": {
        "foreground": "#1F1E1D"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#C44D3E"
      }
    },
    {
      "scope": ["entity.other.attribute-name"],
      "settings": {
        "foreground": "#B56613"
      }
    },
    {
      "scope": ["support.constant", "variable.other.constant"],
      "settings": {
        "foreground": "#2D8F8F"
      }
    },
    {
      "scope": ["meta.decorator", "entity.name.function.decorator"],
      "settings": {
        "foreground": "#B56613"
      }
    },
    {
      "scope": [
        "punctuation.section",
        "punctuation.separator",
        "punctuation.accessor",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#6B6A68"
      }
    },
    {
      "scope": ["string.regexp"],
      "settings": {
        "foreground": "#C44D3E"
      }
    },
    {
      "scope": ["constant.character.escape", "string.template punctuation.definition"],
      "settings": {
        "foreground": "#2D8F8F"
      }
    },
    {
      "scope": ["entity.name.namespace", "entity.name.module"],
      "settings": {
        "foreground": "#8A46CE"
      }
    },
    {
      "scope": ["markup.heading"],
      "settings": {
        "foreground": "#C96442",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["markup.bold"],
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["markup.italic"],
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["markup.inline.raw", "markup.fenced_code"],
      "settings": {
        "foreground": "#2D8F8F"
      }
    },
    {
      "scope": ["markup.underline.link"],
      "settings": {
        "foreground": "#6A9BCC"
      }
    },
    {
      "scope": ["markup.inserted"],
      "settings": {
        "foreground": "#788C5D"
      }
    },
    {
      "scope": ["markup.deleted"],
      "settings": {
        "foreground": "#C44D3E"
      }
    },
    {
      "scope": ["markup.changed"],
      "settings": {
        "foreground": "#D97757"
      }
    },
    {
      "scope": [
        "source.json support.type.property-name"
      ],
      "settings": {
        "foreground": "#C96442"
      }
    },
    {
      "scope": ["support.type.property-name.css"],
      "settings": {
        "foreground": "#1F6FE4"
      }
    },
    {
      "scope": [
        "support.constant.color",
        "constant.other.color",
        "support.constant.property-value.css"
      ],
      "settings": {
        "foreground": "#2D8F8F"
      }
    },
    {
      "scope": ["entity.name.section", "entity.name.tag.yaml"],
      "settings": {
        "foreground": "#C96442"
      }
    },
    {
      "scope": ["variable.language"],
      "settings": {
        "foreground": "#D73A83",
        "fontStyle": "italic"
      }
    }
  ],
  "semanticTokenColors": {
    "function": "#1F6FE4",
    "function.declaration": "#1F6FE4",
    "method": "#1F6FE4",
    "method.declaration": "#1F6FE4",
    "variable": "#1F1E1D",
    "variable.readonly": "#2D8F8F",
    "parameter": "#B56613",
    "property": "#1F1E1D",
    "type": "#8A46CE",
    "class": "#8A46CE",
    "interface": "#8A46CE",
    "enum": "#8A46CE",
    "enumMember": "#2D8F8F",
    "namespace": "#8A46CE",
    "decorator": "#B56613",
    "macro": "#D73A83"
  }
}
